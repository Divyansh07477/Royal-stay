<% layout ("/layouts/boilerplate") %>
<link rel="stylesheet" href="css/style.css">
<div class="row mt-5">
     
        <div class="col-7 offset-2">

    <h3 class="p">
        <%= listing.title %>
    </h3>

    

    <div class="card col-10 offset-1 show-card listing-card">

   <img class="papa"
src="<%= listing.image?.url  %>"
class="card-img-top show-img"
alt="listing_image">

<div class="card-body">

  

  <p class="card-text">
    <%= listing.description %>
  </p>

  <p>
    &#8377;<%= Number(listing.price || 0).toLocaleString("en-IN") %>
  </p>

  <p><%= listing.location %></p>

  <p><%= listing.country %></p>

</div>
    </div>

 <% if (currentUser && listing.owner && listing.owner.equals(currentUser._id)) { %>

<div class="d-flex gap-3 mt-3 justify-content-space-evenly">

    <a href="/listings/<%= listing._id %>/edit"
       class="btn btn-dark col-1 offset-1 edit0btn">
        Edit
    </a>

    <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark offset-2">
            Delete
        </button>
    </form>

</div>

<% } %>
    




 <button class="btn reserve-btn" type="button" onclick="showReserveForm()">
    Reserve
</button>

<div id="reserveForm" class="card p-4 mt-4" style="display:none;">

    <h4 class="mb-3">Reservation Details</h4>

    <form action="/listings/<%= listing._id %>/reserve" method="POST">

        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" class="form-control" name="name" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" name="email" required>
        </div>

         <div class="mb-3">
            <label class="form-label">Phone Number</label>
            <input type="number" class="form-control" name="Phone Number" required>
        </div>


        <div class="row">

            <div class="col-md-6 mb-3">
                <label class="form-label">Check-In</label>
                <input type="date" class="form-control" name="checkin" required>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Check-Out</label>
                <input type="date" class="form-control" name="checkout" required>
            </div>

        </div>

        <div class="mb-3">
            <label class="form-label">Guests</label>
            <input type="number" class="form-control" name="guests" min="1" value="1" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Special Request</label>
            <textarea class="form-control" rows="3" name="request"></textarea>
        </div>

        <button class="btn btn-success w-100">
            Confirm Reservation
        </button>

    </form>

</div>




      </div>

    </div>

 

<div class="col-7 offset-2 ">
  <hr>
  <h4> Leave a Review</h4>
  <form action ="/listings/<%- listing.id%>/reviews" method="post"novalidate class="needs-validation">
        <!-- <div class="mb-3 mt-3">
          <label for="rating" class="form-label"> Rating</label> -->

          <!-- <input type="range" min="1" max="5" id="rating" name="review[rating]"class="form-range">
        </div> -->

<div class="mb-3 mt-3">
  <label class="form-label">Rating</label>

  <div class="star-rating">

    <input type="radio" id="5-stars" name="review[rating]" value="5" required>
    <label for="5-stars">★</label>

    <input type="radio" id="4-stars" name="review[rating]" value="4">
    <label for="4-stars">★</label>

    <input type="radio" id="3-stars" name="review[rating]" value="3">
    <label for="3-stars">★</label>

    <input type="radio" id="2-stars" name="review[rating]" value="2">
    <label for="2-stars">★</label>

    <input type="radio" id="1-star" name="review[rating]" value="1">
    <label for="1-star">★</label>

  </div>
</div>



       
        <div class="mb-3 mt-3 mj">
          <label for="comment" class="form-label"> Comments</label>
          <textarea name="review[comment]" id="comment" cols="10" rows="5" class="form-control w-100" style= "max-width: 900px;" required></textarea>
   <div class="invalid-feedback">Please sumbit some comments for review</div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
  </form>
  <hr>
  <p>
    <b>All Reviews</b></p>
   

<div class="row">
    <% for (let review of listing.reviews) { %>
    <div class="card col-5 ms-4 mt-3">
   <div class="card-body">
      <h5 class="card-title">MJ</h5>
       <p class="card-text"><%= review.comment %></p>
       <p class="card-text"><%= review.rating %>Star</p>
      

</div>
<form class="mb-3" method="post" action="/listings/<%=listing._id %>/reviews/<%= review._id %>?_method=DELETE">
  <button class="btn btn-sm btn-dark"> Delete</button>
</form>
    </div>

  <% } %>
</div>








<hr>

<h4 class="mt-4">Where you'll be</h4>

<div class="map-container mt-3">
    <iframe
        src="https://www.google.com/maps?q=<%= listing.location %>&output=embed"
        width="100%"
        height="400"
        style="border:0; border-radius:15px;"
        allowfullscreen=""
        loading="lazy">
    </iframe>
</div>
</div>




<script>
function showReserveForm() {
    let form = document.getElementById("reserveForm");

    if (form.style.display === "none") {
        form.style.display = "block";
    } else {
        form.style.display = "none";
    }
}
</script>









<script>

async function getWeather() {

   let city = "<%= listing.location %>,<%= listing.country %>";
    let apiKey = "YOUR_REAL_API_KEY";

    try {

        let response = await fetch(
            `https://api.openweathermap.org/data/2.5/weather?q=${city}&appid=${apiKey}&units=metric`
        );

        let data = await response.json();

        console.log(data);

        if(data.cod != 200){

            document.getElementById("weather").innerText =
            "City not found";

            return;
        }

        document.getElementById("weather").innerText =
        `${Math.round(data.main.temp)}°C in ${city}`;

    }

    catch(err){

        document.getElementById("weather").innerText =
        "Weather unavailable";
    }
}

getWeather();

</script>



